# Telegram API credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=replace-with-api-hash
# Group/channel username, invite URL, t.me URL, or numeric entity id your account can access.
TELEGRAM_GROUP=example_group
# Optional number of historical messages to ingest. Omit for Telethon default pagination behavior.
TELEGRAM_LIMIT=1000
# Optional existing Telethon session file name/path. Keep this file private.
TELEGRAM_SESSION=telegram_ingest

# Databricks SQL Warehouse / compute connection settings.
# Example host: adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_SERVER_HOSTNAME=replace-with-workspace-hostname
# Example path: /sql/1.0/warehouses/abc123def456ghi7
DATABRICKS_HTTP_PATH=replace-with-sql-warehouse-http-path
DATABRICKS_ACCESS_TOKEN=replace-with-personal-access-token
# Three-part Unity Catalog table name is recommended.
DATABRICKS_TABLE=main.default.telegram_messages

# Optional ingestion tuning.
BATCH_SIZE=500

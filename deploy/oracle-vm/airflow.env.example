# Copy this file to airflow.env on the Oracle VM. Never commit airflow.env.
# Use only letters/numbers for POSTGRES_PASSWORD because it is embedded in a URL.
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_ALPHANUMERIC_PASSWORD
AIRFLOW_FERNET_KEY=REPLACE_WITH_FERNET_KEY
AIRFLOW_WEBSERVER_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
AIRFLOW_UID=50000

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=you@example.com

# Telegram credentials. Protect this file with chmod 600.
TELEGRAM_API_ID=REPLACE_WITH_TELEGRAM_API_ID
TELEGRAM_API_HASH=REPLACE_WITH_TELEGRAM_API_HASH
TELEGRAM_SESSION_STRING=REPLACE_WITH_TELEGRAM_STRING_SESSION

# Sources. Add TELEGRAM_CHANNEL_4, _5, ... up to _100 in the future.
TELEGRAM_CHANNEL=CarpoolSgJb
TELEGRAM_CHANNEL_2=TeleHitch
TELEGRAM_CHANNEL_2_TOPIC_ID=1823745
# TELEGRAM_CHANNEL_3=kenny9966JBSGJBcarpool
# TELEGRAM_CHANNEL_3_TOPIC_ID=
TELEGRAM_AIRFLOW_SCHEDULE=*/15 * * * *
TELEGRAM_BACKFILL_PAGE_LIMIT=500
TELEGRAM_PER_RUN_LIMIT=0
# TELEGRAM_SINCE_YEAR=

# Databricks SQL warehouse.
DATABRICKS_SERVER_HOSTNAME=REPLACE_WITH_HOSTNAME_WITHOUT_HTTPS
DATABRICKS_HTTP_PATH=REPLACE_WITH_SQL_WAREHOUSE_HTTP_PATH
DATABRICKS_TOKEN=REPLACE_WITH_DATABRICKS_TOKEN
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=default
DATABRICKS_TABLE=sgjb-telehitch-raw
DATABRICKS_BATCH_SIZE=100
